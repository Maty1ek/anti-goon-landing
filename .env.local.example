# Copy this file to .env.local and fill in real values.
# Vercel: set these in Project Settings -> Environment Variables.

# ---- Server-only (never exposed to the browser) ----
# Supabase project + service role key. The service role bypasses RLS;
# it lives only in API routes (app/api/_lib/account-ops.js).
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# Whop API key, scope: membership:cancel
WHOP_API_KEY=whop_...

# ---- Public (baked into the static HTML) ----
# Social + contact links. Used in the footer. The NEXT_PUBLIC_ prefix
# is required for Next.js to expose them to the browser.
NEXT_PUBLIC_TIKTOK_URL=https://www.tiktok.com/@your-handle
NEXT_PUBLIC_X_URL=https://x.com/your-handle
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/your-handle
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/your-invite
NEXT_PUBLIC_CONTACT_EMAIL=hello@your-domain.com
